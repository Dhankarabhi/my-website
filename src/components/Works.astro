---
import Bars from "./Bars.astro"
import Reveal from "./Reveal.jsx"
import svgUnderline from "../assets/underline.svg"
import arrowCard from "../assets/arrow-card.svg"
import { getAllProjects } from "../projectData"

const projects = getAllProjects().filter((p) => p.featured)
---

<section class="py-20 px-5" id="work">
  <!-- Section heading (same proven pattern as /projects page) -->
  <div class="text-center mb-15 max-w-md mx-auto">
    <div class="flex items-center justify-center gap-3 mb-2 animate-kicker-in">
      <span class="h-[2px] w-6 bg-[var(--blue)]"></span>
      <span class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--blue)]">Portfolio</span>
      <span class="h-[2px] w-6 bg-[var(--blue)]"></span>
    </div>
    <h1 class="text-4xl font-medium animate-heading-pop">Featured Projects</h1>
    <div class="flex justify-center mt-2">
      <img src={svgUnderline.src} alt="underline" width="140" class="animate-underline-combined" />
    </div>
  </div>

  <!-- Project cards (same proven card pattern as /projects page) -->
  <div class="max-w-3xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
    {projects.map((project, index) => (
      <Reveal client:visible as="div" delay={(index % 2) * 120} className="bg-white border-3 shadow-[6px_6px_0px_rgba(0,0,0,0.3)] group hover:shadow-[12px_12px_0px_rgba(0,0,0,0.3)] hover:-translate-y-2 transition-all duration-300 relative overflow-hidden">
        <Bars />

        <!-- Project Image -->
        <div class="w-full h-[200px] overflow-hidden border-b-3 bg-gray-100 relative flex items-center justify-center">
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-1 text-gray-400">
            <span class="text-3xl">🖼️</span>
            <span class="text-xs font-medium">Image not available</span>
          </div>
          <img
            src={project.mainImage}
            alt={project.name}
            class="relative w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            loading="lazy"
            onerror="this.style.display='none';"
          />
        </div>

        <!-- Project Content -->
        <div class="p-6">
          <div class="flex items-start justify-between gap-3 mb-3">
            <h2 class="text-xl font-bold group-hover:text-blue-600 transition-colors duration-200">{project.name}</h2>
            <a href={`/projects/${project.id}`} class="flex-shrink-0 flex items-center justify-center w-9 h-9 border-2 border-black transition-all duration-300 group-hover:bg-[var(--yellow)] group-hover:rotate-45">
              <img src={arrowCard.src} alt="view project" width="16" />
            </a>
          </div>

          <p class="text-gray-700 mb-4 line-clamp-3">{project.description}</p>

          <a href={`/projects/${project.id}`} class="inline-block bg-black text-white text-center py-2.5 px-5 font-medium border-2 border-black hover:bg-[var(--yellow)] hover:text-black transition-colors duration-200">
            View Details
          </a>
        </div>
      </Reveal>
    ))}
  </div>

  <!-- View all -->
  <div class="text-center mt-14">
    <a href="/projects" class="group inline-flex items-center gap-2 px-6 py-3 bg-black text-white font-medium border-3 border-black hover:bg-white hover:text-black transition-all duration-200">
      View All Projects
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="transition-transform duration-300 group-hover:translate-x-1">
        <path d="M16.01 11H4v2h12.01v3L20 12l-3.99-4v3z"/>
      </svg>
    </a>
  </div>
</section>

<style>
  @keyframes fade-in-work {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-work {
    animation: fade-in-work 0.6s ease-out forwards;
  }
  .animate-fade-in-work-delay {
    animation: fade-in-work 0.6s ease-out 0.2s forwards;
    opacity: 0;
  }

  @keyframes underline-grow-in {
    from { opacity: 0; transform: scaleX(0); }
    to { opacity: 1; transform: scaleX(1); }
  }
  @keyframes underline-pulse-glow {
    0%, 100% { transform: scaleX(1) scaleY(1); filter: drop-shadow(0 0 0 rgba(255, 220, 88, 0)); }
    50% { transform: scaleX(1) scaleY(1.3); filter: drop-shadow(0 0 5px rgba(255, 220, 88, 0.7)); }
  }
  .animate-underline-combined {
    transform-origin: center;
    opacity: 0;
    animation:
      underline-grow-in 0.6s ease-out 0.3s forwards,
      underline-pulse-glow 2.2s ease-in-out 1.2s infinite;
  }
  @keyframes kicker-in {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-kicker-in {
    animation: kicker-in 0.6s ease-out forwards;
    opacity: 0;
  }

  @keyframes heading-pop {
    0% { opacity: 0; transform: scale(0.85); }
    60% { opacity: 1; transform: scale(1.04); }
    100% { opacity: 1; transform: scale(1); }
  }
  .animate-heading-pop {
    animation: heading-pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.15s both;
  }
</style>