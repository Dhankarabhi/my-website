---
import '../styles/global.css'
import Layout from '../layouts/Layout.astro';
import AppHeader from '../components/Header.astro';
import AppFooter from '../components/Footer.astro';
import CallToAction from '../components/CallToAction.astro';
import Button from '../components/Button.astro';
import Bars from '../components/Bars.astro';

import svgPinkStar from '../assets/pink-star.svg'
import svgRedStar from '../assets/red-star.svg'

const { project } = Astro.props;
---

<Layout>
  <AppHeader />

  <section class="py-20 px-5 relative overflow-hidden">
    <img src={svgPinkStar.src} alt="svg" width="60" class="absolute -right-6 top-10" />
    <img src={svgRedStar.src} alt="svg" width="40" class="absolute left-10 bottom-20" />

    <div class="max-w-4xl mx-auto">

      <!-- Safety Guard -->
      {!project && (
        <div class="bg-white border-3 p-10 text-center">
          <h1 class="text-3xl font-bold mb-4">Project not found</h1>
          <p class="text-gray-600 mb-6">This project is not available yet.</p>
          <Button text="Back to Portfolio" link="/#work" target="_self" />
        </div>
      )}

      {project && (
        <>
          <!-- Project Header -->
          <div class="bg-white border-3 shadow-[8px_8px_0px_rgba(0,0,0,0.3)] p-8 mb-10 relative">
            <Bars />

            <div class="grid grid-cols-1 md:grid-cols-[60%_40%] gap-8 items-center">
              <div>
                <h1 class="text-4xl font-bold mb-4">{project.name}</h1>
                <p class="text-xl text-gray-700 mb-6">{project.description}</p>

                <!-- Tech Stack -->
                {project.technologies && (
                  <div class="mb-6">
                    <h3 class="text-lg font-medium mb-3">Technologies Used:</h3>
                    <div class="flex flex-wrap gap-2">
                      {project.technologies.map((tech) => (
                        <span class="px-3 py-1 bg-[var(--yellow)] border-2 border-black text-sm font-medium">
                          {tech}
                        </span>
                      ))}
                    </div>
                  </div>
                )}

                <div class="flex flex-col sm:flex-row gap-4">
                  <Button text="View Live Demo" link={project.liveUrl} target="_blank" />
                  <Button text="GitHub Repository" link={project.githubUrl} target="_blank" />
                </div>
              </div>

              <!-- Main Image -->
              <div class="relative">
                <div
                  class="w-full h-[280px] border-3 overflow-hidden bg-gray-100 cursor-pointer relative group"
                  data-image={project.mainImage}
                  data-caption={`${project.name} - Main Project Image`}
                >
                  <img
                    src={project.mainImage}
                    alt={project.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    onerror="this.style.display='none'; this.parentElement.classList.add('bg-black');"
                  />

                  <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-30 transition-all duration-300 flex items-center justify-center">
                    <div class="text-white text-4xl opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                      🔍
                    </div>
                  </div>
                </div>

                <img src={svgPinkStar.src} alt="star" width="30" class="absolute -top-3 -right-3" />
              </div>
            </div>
          </div>

          <!-- Stats -->
          {project.stats && (
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
              <div class="bg-white border-2 p-6 text-center">
                <h3 class="text-2xl font-bold text-[var(--blue)] mb-2">{project.stats.duration}</h3>
                <p class="font-medium">Development Time</p>
              </div>
              <div class="bg-white border-2 p-6 text-center">
                <h3 class="text-2xl font-bold text-[var(--blue)] mb-2">{project.stats.complexity}</h3>
                <p class="font-medium">Complexity Level</p>
              </div>
              <div class="bg-white border-2 p-6 text-center">
                <h3 class="text-2xl font-bold text-[var(--blue)] mb-2">{project.stats.impact}</h3>
                <p class="font-medium">Performance Impact</p>
              </div>
            </div>
          )}

          <!-- Overview -->
          <div class="bg-white border-3 p-8 mb-10">
            <h2 class="text-3xl font-bold mb-6">Project Overview</h2>
            <p class="text-lg leading-relaxed mb-6">{project.longDescription}</p>

            {project.features && (
              <>
                <h3 class="text-xl font-bold mb-4">Key Features:</h3>
                <ul class="space-y-2 mb-8">
                  {project.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <span class="w-2 h-2 bg-black rounded-full mt-3 flex-shrink-0"></span>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </>
            )}

            {project.challenges && (
              <>
                <h3 class="text-xl font-bold mb-4">Challenges & Solutions:</h3>
                <div class="space-y-4">
                  {project.challenges.map((challenge) => (
                    <div class="border-l-4 border-[var(--yellow)] pl-4">
                      <h4 class="font-medium mb-2">{challenge.problem}</h4>
                      <p class="text-gray-700">{challenge.solution}</p>
                    </div>
                  ))}
                </div>
              </>
            )}
          </div>

          <!-- Screenshots (SAFE) -->
          {project.screenshots && project.screenshots.length > 0 && (
            <div class="mb-10">
              <h2 class="text-3xl font-bold mb-6 text-center">Project Screenshots</h2>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {project.screenshots.map((screenshot) => (
                  <div class="bg-white border-2 p-4 group hover:shadow-[4px_4px_0px_rgba(0,0,0,0.3)] transition-all duration-200">
                    <div
                      class="w-full h-[200px] border-2 overflow-hidden mb-3 cursor-pointer"
                      data-image={screenshot.url}
                      data-caption={screenshot.caption}
                    >
                      <img
                        src={screenshot.url}
                        alt={screenshot.caption}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                    <p class="text-sm font-medium text-center">{screenshot.caption}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Architecture -->
          {project.architecture && (
            <div class="bg-white border-3 p-8 mb-10">
              <h2 class="text-3xl font-bold mb-6">System Architecture</h2>

              <div
                class="w-full h-[300px] border-2 bg-gray-50 flex items-center justify-center mb-4 cursor-pointer"
                data-image={project.architecture.diagram}
                data-caption={`${project.name} - Architecture Diagram`}
              >
                <img
                  src={project.architecture.diagram}
                  alt="Architecture Diagram"
                  class="max-w-full max-h-full object-contain"
                />
              </div>

              <p class="text-gray-700">{project.architecture.description}</p>
            </div>
          )}

          <div class="text-center">
            <Button text="← Back to Portfolio" link="/#work" target="_self" />
          </div>
        </>
      )}
    </div>
  </section>

  <!-- Modal -->
  <div id="imageModal" class="fixed inset-0 bg-black bg-opacity-90 z-50 hidden flex items-center justify-center p-4">
    <div class="relative max-w-6xl max-h-full w-full">
      <button id="closeModal" class="absolute -top-12 right-0 text-white text-2xl bg-black bg-opacity-50 px-4 py-2 border-2 border-white">
        ✕ Close
      </button>

      <div class="bg-white border-3 border-black p-6 max-h-[90vh] overflow-auto shadow-2xl">
        <img id="modalImage" src="" alt="" class="max-w-full h-auto mx-auto block" />
        <p id="modalCaption" class="text-center font-bold mt-6 text-xl text-gray-800"></p>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const modal = document.getElementById('imageModal');
      const modalImage = document.getElementById('modalImage');
      const modalCaption = document.getElementById('modalCaption');
      const closeBtn = document.getElementById('closeModal');

      function openModal(imageSrc, caption) {
        if (!imageSrc) return;
        modalImage.src = imageSrc;
        modalCaption.textContent = caption || "";
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }

      document.querySelectorAll('[data-image]').forEach(function (el) {
        el.addEventListener('click', function () {
          openModal(
            el.getAttribute('data-image'),
            el.getAttribute('data-caption')
          );
        });
      });

      closeBtn.addEventListener('click', closeModal);
      modal.addEventListener('click', function (e) {
        if (e.target === modal) closeModal();
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeModal();
      });
    });
  </script>

  <CallToAction />
  <AppFooter />
</Layout>
