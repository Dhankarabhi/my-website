---
import svgPinkStar from '../assets/pink-star.svg'

const commands = [
  { prompt: "kubectl get pods -n production", output: "3/3 pods Running — 0 restarts" },
  { prompt: "terraform apply -auto-approve", output: "Apply complete! Resources: 12 added" },
  { prompt: "docker ps --format 'table {{.Names}}'", output: "api  worker  redis  nginx" },
  { prompt: "ansible-playbook deploy.yml", output: "PLAY RECAP — ok=14 failed=0" },
  { prompt: "git push origin main", output: "CI/CD pipeline triggered ✓" },
]
---

<section class="px-5 pb-16 relative">
  <img src={svgPinkStar.src} alt="" width="45" class="absolute left-6 top-2 opacity-40 animate-float hidden md:block" />

  <div class="max-w-2xl mx-auto relative">
    <div class="text-center mb-8">
      <span class="block text-sm font-bold uppercase tracking-[0.2em] text-[var(--blue)] mb-2">Behind the scenes</span>
      <h2 class="text-3xl font-medium">A Peek Into My Terminal</h2>
    </div>

    <div class="bg-white rounded-none border-3 border-black shadow-[8px_8px_0px_rgba(0,0,0,0.3)] overflow-hidden">
      <!-- Title bar - matches site's bold black-on-white style -->
      <div class="flex items-center gap-2 px-4 py-3 bg-black border-b-3 border-black">
        <span class="w-3 h-3 rounded-full bg-[var(--yellow)] border border-white/40"></span>
        <span class="w-3 h-3 rounded-full bg-[var(--blue)] border border-white/40"></span>
        <span class="w-3 h-3 rounded-full bg-white border border-white/40"></span>
        <span class="ml-3 text-xs text-white/70 font-mono">abhishek@devops:~</span>
      </div>

      <!-- Terminal body -->
      <div class="p-5 font-mono text-sm leading-relaxed min-h-[110px] bg-[#fafaf5]" id="terminal-body">
        <span class="text-[var(--blue)] font-bold">$</span>
        <span id="terminal-text" class="text-black"></span><span id="terminal-cursor" class="inline-block w-[8px] h-[15px] bg-black align-middle animate-cursor-blink"></span>
        <div id="terminal-output" class="text-gray-500 mt-1 opacity-0 transition-opacity duration-300"></div>
      </div>
    </div>

    <img src={svgPinkStar.src} alt="" width="30" class="absolute -bottom-4 -right-3" />
  </div>
</section>

<script define:vars={{ commands }}>
  document.addEventListener('DOMContentLoaded', () => {
    const textEl = document.getElementById('terminal-text');
    const outputEl = document.getElementById('terminal-output');
    if (!textEl || !outputEl) return;

    let cmdIndex = 0;
    let charIndex = 0;
    let typing = true;

    function tick() {
      const current = commands[cmdIndex];

      if (typing) {
        if (charIndex <= current.prompt.length) {
          textEl.textContent = current.prompt.slice(0, charIndex);
          charIndex++;
          setTimeout(tick, 45);
        } else {
          outputEl.textContent = current.output;
          outputEl.style.opacity = '1';
          setTimeout(() => {
            typing = false;
            tick();
          }, 1400);
        }
      } else {
        if (charIndex >= 0) {
          textEl.textContent = current.prompt.slice(0, charIndex);
          charIndex--;
          setTimeout(tick, 20);
        } else {
          outputEl.style.opacity = '0';
          outputEl.textContent = '';
          cmdIndex = (cmdIndex + 1) % commands.length;
          charIndex = 0;
          typing = true;
          setTimeout(tick, 300);
        }
      }
    }

    tick();
  });
</script>

<style>
  @keyframes cursor-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  .animate-cursor-blink {
    animation: cursor-blink 1s step-start infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(8deg); }
  }
  .animate-float {
    animation: float 5s ease-in-out infinite;
  }
</style>