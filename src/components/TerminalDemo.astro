---
import svgPinkStar from '../assets/pink-star.svg'

const commands = [
  { prompt: "kubectl get pods -n production", output: "3/3 pods Running — 0 restarts" },
  { prompt: "terraform apply -auto-approve", output: "Apply complete! Resources: 12 added" },
  { prompt: "docker ps --format 'table {{.Names}}'", output: "api  worker  redis  nginx" },
  { prompt: "ansible-playbook deploy.yml", output: "PLAY RECAP — ok=14 failed=0" },
  { prompt: "git push origin main", output: "CI/CD pipeline triggered" },
]
---

<section class="px-5 pb-16 relative">
  <img src={svgPinkStar.src} alt="" width="45" class="absolute left-6 top-2 opacity-40 animate-float hidden md:block" />

  <div class="max-w-2xl mx-auto relative">
    <div class="text-center mb-8">
      <span class="block text-sm font-bold uppercase tracking-[0.2em] text-[var(--blue)] mb-2">Behind the scenes</span>
      <h2 class="text-3xl font-medium">A Peek Into My Terminal</h2>
    </div>

    <div class="relative animate-terminal-in">
      <!-- Soft glow pulse behind the terminal -->
      <div class="absolute -inset-2 rounded-xl bg-[var(--blue)] opacity-0 blur-xl animate-terminal-glow"></div>

      <div class="relative bg-white rounded-none border-3 border-black shadow-[8px_8px_0px_rgba(0,0,0,0.3)] overflow-hidden">
        <!-- Title bar -->
        <div class="flex items-center gap-2 px-4 py-3 bg-black border-b-3 border-black">
          <span class="w-3 h-3 rounded-full bg-[var(--yellow)] border border-white/40 animate-dot-pulse" style="animation-delay:0s"></span>
          <span class="w-3 h-3 rounded-full bg-[var(--blue)] border border-white/40 animate-dot-pulse" style="animation-delay:0.3s"></span>
          <span class="w-3 h-3 rounded-full bg-white border border-white/40 animate-dot-pulse" style="animation-delay:0.6s"></span>
          <span class="ml-3 text-xs text-white/70 font-mono">abhishek@devops:~</span>
        </div>

        <!-- Terminal body -->
        <div class="p-5 font-mono text-sm leading-relaxed min-h-[110px] bg-[#fafaf5]" id="terminal-body">
          <span class="text-[var(--blue)] font-bold">$</span>
          <span id="terminal-text" class="text-black"></span><span id="terminal-cursor" class="inline-block w-[8px] h-[15px] bg-black align-middle animate-cursor-blink"></span>
          <div id="terminal-processing" class="text-gray-400 mt-1 opacity-0">
            <span class="animate-dot-1">.</span><span class="animate-dot-2">.</span><span class="animate-dot-3">.</span>
          </div>
          <div id="terminal-output" class="mt-1 opacity-0 transition-opacity duration-300 flex items-center gap-2">
            <span class="text-green-500 font-bold">✓</span>
            <span id="terminal-output-text" class="text-green-600"></span>
          </div>
        </div>
      </div>
    </div>

    <img src={svgPinkStar.src} alt="" width="30" class="absolute -bottom-4 -right-3" />
  </div>
</section>

<script define:vars={{ commands }}>
  document.addEventListener('DOMContentLoaded', () => {
    const textEl = document.getElementById('terminal-text');
    const outputEl = document.getElementById('terminal-output');
    const outputTextEl = document.getElementById('terminal-output-text');
    const processingEl = document.getElementById('terminal-processing');
    if (!textEl || !outputEl || !outputTextEl || !processingEl) return;

    let cmdIndex = 0;
    let charIndex = 0;
    let typing = true;

    function tick() {
      const current = commands[cmdIndex];

      if (typing) {
        if (charIndex <= current.prompt.length) {
          textEl.textContent = current.prompt.slice(0, charIndex);
          charIndex++;
          setTimeout(tick, 45);
        } else {
          // show "processing..." dots briefly before the output appears
          processingEl.style.opacity = '1';
          setTimeout(() => {
            processingEl.style.opacity = '0';
            outputTextEl.textContent = current.output;
            outputEl.style.opacity = '1';
            setTimeout(() => {
              typing = false;
              tick();
            }, 1300);
          }, 500);
        }
      } else {
        if (charIndex >= 0) {
          textEl.textContent = current.prompt.slice(0, charIndex);
          charIndex--;
          setTimeout(tick, 20);
        } else {
          outputEl.style.opacity = '0';
          outputTextEl.textContent = '';
          cmdIndex = (cmdIndex + 1) % commands.length;
          charIndex = 0;
          typing = true;
          setTimeout(tick, 300);
        }
      }
    }

    tick();
  });
</script>

<style>
  @keyframes cursor-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  .animate-cursor-blink {
    animation: cursor-blink 1s step-start infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(8deg); }
  }
  .animate-float {
    animation: float 5s ease-in-out infinite;
  }

  /* Entrance: fade + slight rise + scale */
  @keyframes terminal-in {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .animate-terminal-in {
    animation: terminal-in 0.7s ease-out forwards;
  }

  /* Soft glow pulse behind the card */
  @keyframes terminal-glow {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.35; }
  }
  .animate-terminal-glow {
    animation: terminal-glow 4s ease-in-out 0.8s infinite;
  }

  /* Traffic-light dots gentle pulse */
  @keyframes dot-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.25); opacity: 0.7; }
  }
  .animate-dot-pulse {
    animation: dot-pulse 2s ease-in-out infinite;
  }

  /* Processing "..." dots, staggered */
  @keyframes dot-blink {
    0%, 20% { opacity: 0.2; }
    50% { opacity: 1; }
    100% { opacity: 0.2; }
  }
  .animate-dot-1 { animation: dot-blink 1s ease-in-out infinite; animation-delay: 0s; }
  .animate-dot-2 { animation: dot-blink 1s ease-in-out infinite; animation-delay: 0.2s; }
  .animate-dot-3 { animation: dot-blink 1s ease-in-out infinite; animation-delay: 0.4s; }
</style>